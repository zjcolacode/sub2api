# Caddyfile —— 自动 TLS + 反向代理到 sub2api (127.0.0.1:8080)
# 域名通过环境变量 DOMAIN 注入（setup-app.sh 会传）

{$DOMAIN} {
	# 流式响应关键：禁用缓冲，收到字节立即转发（SSE 必需）
	reverse_proxy 127.0.0.1:8080 {
		flush_interval -1
		transport http {
			read_timeout 0
			write_timeout 0
			dial_timeout 10s
		}
	}

	# 请求体上限（图片/文件上传）
	request_body {
		max_size 100MB
	}

	# 压缩（注意：流式响应不会被压缩，仅静态资源受益）
	encode zstd gzip

	# 静态资源长缓存
	@static path /assets/* /logo.png /favicon.ico
	header @static Cache-Control "public, max-age=31536000, immutable"

	# 访问日志
	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}
}
